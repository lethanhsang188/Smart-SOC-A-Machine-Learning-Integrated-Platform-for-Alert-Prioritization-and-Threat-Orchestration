# Core API
ML_HOST=0.0.0.0
ML_PORTS=8000
ML_INGEST_API_KEY=change-me

# Malware detection model
ML_MODEL_PATH=./ember2024_pe_lgbm.model
ML_MALWARE_THRESHOLD=0.5
ML_SUSPICIOUS_TOOL_THRESHOLD=0.30
ML_LOG_CSV=./logs/malware_logs.csv

# PE extractor service
ML_SERVER_URL=http://127.0.0.1:8000/predict-features
PE_SCAN_DIR=
PE_AUTO_SCAN_ON_START=0
PE_WATCH_SCAN_DIR=0
PE_WATCH_INTERVAL_SECONDS=10

# Wazuh alert prioritization
ALERT_PRIORITY_MODEL_PATH=./alert_priority/models/alert_priority_model.joblib
ALERT_PRIORITY_NOTIFY_THRESHOLD=0.70
ML_INGEST_BLOCK_PRIORITIES=P1,P2
ML_INGEST_NOTIFY_PRIORITIES=P1,P2

# SOAR / response integrations
SHUFFLE_MALWARE_WEBHOOK=
SHUFFLE_RESPONSE_WEBHOOK=
SHUFFLE_VERIFY_SSL=0
SHUFFLE_RESPONSE_VERIFY_SSL=0
SHUFFLE_RESPONSE_TIMEOUT=8

# pfSense blocking integration
PFSENSE_ALIAS_URL=
PFSENSE_API_KEY=
PFSENSE_ALIAS_NAME=WAZUH_BLOCK
PFSENSE_VERIFY_SSL=0
PFSENSE_TIMEOUT=8

# Telegram notification integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT=8
